{
  "openapi": "3.0.0",
  "info": {
    "title": "Action Resource API",
    "version": "1.0.0",
    "description": "Provides comprehensive access to Actions within an AccelQ project. Supports advanced filtering, pagination, and retrieval of Action custom fields and references."
  },
  "servers": [
    {
      "url": "{accelqLoginUrl}/awb/api/2.0/{tenantCode}/{projectCode}",
      "variables": {
        "accelqLoginUrl": {
          "default": "https://org.accelq.io",
          "description": "The AccelQ login URL for API access."
        },
        "tenantCode": {
          "default": "tenantCode",
          "description": "Tenant code for identifying the organization."
        },
        "projectCode": {
          "default": "projectCode",
          "description": "Project Code found under Auth properties of ACCELQ User Profile."
        }
      }
    }
  ],
  "components": {
    "securitySchemes": {
      "user_id": {
        "type": "apiKey",
        "in": "header",
        "name": "user_id",
        "description": "Login Email."
      },
      "api_key": {
        "type": "apiKey",
        "in": "header",
        "name": "api_key",
        "description": "API Key found under Auth Properties in ACCELQ User Profile."
      }
    }
  },
  "security": [
    {
      "user_id": [],
      "api_key": []
    }
  ],
  "paths": {
    "/ctx/actions/fetch-details": {
      "post": {
        "tags": ["Action"],
        "summary": "Fetch Action details",
        "description": "Fetches comprehensive information about Actions within your project. This endpoint supports:\n\n- **Pagination**: Control response size with configurable page numbers and sizes (max 25 items per page)\n- **Flexible Filtering**: Filter by specific Action IDs \n- **Optional Detailed Information**: Selectively include Action Custom fields \n- **User-Specific Version View**: Results reflect the requesting user’s current version of the entities.",
        "operationId": "fetchActionDetails",
        "parameters": [
          {
            "name": "pageNumber",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 1
            },
            "description": "Page number for pagination."
          },
          {
            "name": "pageSize",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 20
            },
            "description": "Number of Actions to return per page (Max 25)."
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "filter": {
                    "type": "object",
                    "properties": {
                      "actionIds": {
                        "type": "array",
                        "items": {
                          "type": "integer"
                        },
                        "description": "Optional list of Action IDs to filter results.",
                        "example": [463, 1134]
                      }
                    }
                  },
                  "additionalDetails": {
                    "type": "object",
                    "properties": {
                      "customFields": {
                        "type": "boolean",
                        "description": "Flag to include Action Custom fields.",
                        "default": true
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful retrieval of Action details.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "page": { "type": "integer", "example": 1 },
                    "pageSize": { "type": "integer", "example": 10 },
                    "totalPages": { "type": "integer", "example": 1 },
                    "totalCount": { "type": "integer", "example": 1 },
                    "results": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "id": { "type": "integer", "example": 463 },
                          "name": {
                            "type": "string",
                            "example": "Login Action"
                          },
                          "description": { "type": "string" },
                          "status": {
                            "type": "string",
                            "example": "Work In Progress"
                          },
                          "createdBy": {
                            "type": "string",
                            "example": "Tenant Admin"
                          },
                          "createdTimestamp": {
                            "type": "string",
                            "format": "date-time",
                            "example": "2026-02-20T02:47:01Z"
                          },
                          "lastModifiedBy": {
                            "type": "string",
                            "example": "Tenant Admin"
                          },
                          "lastModifiedTimestamp": {
                            "type": "string",
                            "format": "date-time",
                            "example": "2026-02-20T02:50:40Z"
                          },
                          "tags": {
                            "example": ["Smoke", "Sanity"]
                          },
                          "customFields": {
                            "type": "object",
                            "properties": {
                              "Priority": {
                                "type": "string",
                                "example": "High"
                              },
                              "Reviewers": {
                                "type": "array",
                                "items": { "type": "string" },
                                "example": ["Stephan"]
                              }
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - Invalid authentication credentials",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string",
                      "example": "Invalid user credentials or API key"
                    }
                  }
                }
              }
            }
          },
          "403": {
            "description": "Forbidden",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string",
                      "example": "Unauthorized Access"
                    }
                  }
                },
                "examples": {
                  "general": {
                    "summary": "authorization Error",
                    "value": {
                      "error": "User does not have authorization to access this feature"
                    }
                  }
                }
              }
            }
          },
          "500": {
            "description": "Internal Server Error",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string",
                      "example": "Error occurred while retrieving Action details"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/ctx/actions/references": {
      "post": {
        "tags": ["Action"],
        "summary": "Fetch Action References",
        "description": "Retrieves the referencing Actions and Scenarios associated with the provided Action IDs. A maximum of 25 Action IDs can be processed per request.",
        "operationId": "fetchActionReferences",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "array",
                "items": {},
                "example": [463, 1134]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful retrieval of Action References.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "id": { "type": "integer", "example": 463 },
                      "name": {
                        "type": "string",
                        "example": "Login Action"
                      },
                      "referencingActions": {
                        "type": "array",
                        "items": {
                          "type": "object",
                          "properties": {
                            "Id": { "type": "integer" },
                            "name": { "type": "string" },
                            "version": { "type": "string" }
                          }
                        },
                        "example": [
                          {
                            "id": 465,
                            "name": "Verify Fund Transfer",
                            "version": "BASE"
                          },
                          {
                            "id": 465,
                            "name": "Verify Fund Transfer",
                            "version": "CHECKED_OUT"
                          },
                          {
                            "id": 475,
                            "name": "Create User Role",
                            "version": "BASE"
                          }
                        ]
                      },
                      "referencingScenarios": {
                        "type": "array",
                        "items": {
                          "type": "object",
                          "properties": {
                            "Id": { "type": "integer" },
                            "name": { "type": "string" },
                            "version": { "type": "string" }
                          }
                        },
                        "example": [
                          {
                            "id": 465,
                            "name": "QBank Sanity",
                            "version": "BASE"
                          },
                          {
                            "id": 475,
                            "name": "Extract Auditing Report",
                            "version": "BASE"
                          }
                        ]
                      }
                    }
                  },
                  "example": [
                    {
                      "id": 463,
                      "name": "Login Action",
                      "referencingActions": [
                        {
                          "id": 465,
                          "name": "Verify Fund Transfer",
                          "version": "BASE"
                        },
                        {
                          "id": 465,
                          "name": "Verify Fund Transfer",
                          "version": "CHECKED_OUT"
                        },
                        {
                          "id": 475,
                          "name": "Create User Role",
                          "version": "BASE"
                        }
                      ],
                      "referencingScenarios": [
                        {
                          "id": 27,
                          "name": "QBank Sanity",
                          "version": "BASE"
                        },
                        {
                          "id": 475,
                          "name": "Extract Auditing Report",
                          "version": "BASE"
                        }
                      ]
                    },
                    {
                      "id": 1134,
                      "name": "Delete Role",
                      "referencingActions": [],
                      "referencingScenarios": []
                    }
                  ]
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - Invalid authentication credentials",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string",
                      "example": "Invalid user credentials or API key"
                    }
                  }
                }
              }
            }
          },
          "403": {
            "description": "Forbidden",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string",
                      "example": "Unauthorized Access"
                    }
                  }
                },
                "examples": {
                  "general": {
                    "summary": "authorization Error",
                    "value": {
                      "error": "User does not have authorization to access this feature"
                    }
                  }
                }
              }
            }
          },
          "500": {
            "description": "Internal Server Error",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string",
                      "example": "Error occurred while retrieving Action References"
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
