{
  "openapi": "3.0.0",
  "info": {
    "title": "Project Configuration API",
    "version": "1.0.0",
    "description": "APIs for managing Project configuration. Only users with Project Admin access can use these APIs."
  },
  "servers": [
    {
      "url": "{accelqLoginUrl}/awb/api/2.0/{tenantCode}/{projectCode}",
      "variables": {
        "accelqLoginUrl": {
          "default": "https://org.accelq.io",
          "description": "The AccelQ login URL for API access."
        },
        "tenantCode": {
          "default": "TenantCode",
          "description": "Tenant code for identifying the organization."
        },
        "projectCode": {
          "default": "ProjectCode",
          "description": "Project Code found under Auth properties of ACCELQ User Profile"
        }
      }
    }
  ],
  "components": {
    "securitySchemes": {
      "UserId": {
        "type": "apiKey",
        "in": "header",
        "name": "user_id",
        "description": "Login Email."
      },
      "ApiKey": {
        "type": "apiKey",
        "in": "header",
        "name": "api_key",
        "description": "API Key found under Auth Properties in ACCELQ User Profile."
      }
    }
  },
  "security": [
    {
      "UserId": [],
      "ApiKey": []
    }
  ],
  "paths": {
    "/conf/app-environments": {
      "get": {
        "tags": ["App Environments"],
        "summary": "List of App Environments",
        "description": "Returns a paginated list of application environments configured for the given Project.",
        "operationId": "getAllAppEnvironments",
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "required": false,
            "description": "Page number for pagination.",
            "schema": {
              "type": "integer",
              "default": 1,
              "example": 1
            }
          },
          {
            "name": "pageSize",
            "in": "query",
            "required": false,
            "description": "Number of items per page (Maximum: 100).",
            "schema": {
              "type": "integer",
              "default": 20,
              "example": 20
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Returns the list of app environments.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "page": {
                      "type": "integer",
                      "example": 1
                    },
                    "pageSize": {
                      "type": "integer",
                      "example": 10
                    },
                    "totalPages": {
                      "type": "integer",
                      "example": 3
                    },
                    "totalCount": {
                      "type": "integer",
                      "example": 21
                    },
                    "results": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "pid": {
                            "type": "integer",
                            "example": 14885
                          },
                          "appEnvironmentName": {
                            "type": "string",
                            "example": "Test"
                          },
                          "description": {
                            "type": "string",
                            "nullable": true,
                            "example": "Testing Environment Data"
                          }
                        }
                      },
                      "example": [
                        {
                          "pid": 1,
                          "appEnvironmentName": "Staging",
                          "description": "Staging Environment"
                        },
                        {
                          "pid": 2,
                          "appEnvironmentName": "Prod",
                          "description": "Prod Environment"
                        },
                        {
                          "pid": 3,
                          "appEnvironmentName": "Live",
                          "description": "Live Environment"
                        },
                        {
                          "pid": 5,
                          "appEnvironmentName": "Staging 2",
                          "description": "Staging Environment"
                        },
                        {
                          "pid": 6,
                          "appEnvironmentName": "Test",
                          "description": "Test Environment"
                        },
                        {
                          "pid": 31,
                          "appEnvironmentName": "Sample",
                          "description": "Environment"
                        },
                        {
                          "pid": 38,
                          "appEnvironmentName": "Prod 2",
                          "description": "Prod2 Environment"
                        },
                        {
                          "pid": 39,
                          "appEnvironmentName": "Staging 3",
                          "description": ""
                        },
                        {
                          "pid": 41,
                          "appEnvironmentName": "Patch",
                          "description": "Patch Environment"
                        },
                        {
                          "pid": 44,
                          "appEnvironmentName": "Next Release",
                          "description": "Environment"
                        }
                      ]
                    }
                  }
                }
              }
            }
          },
          "403": {
            "description": "Forbidden - User does not have permission to fetch app environments",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string",
                      "example": "User do not have authorization to access this feature."
                    }
                  }
                }
              }
            }
          },
          "422": {
            "description": "Project not found.",
            "content": {
              "application/json": {
                "schema": {},
                "example": {
                  "error": "Project with code 'proj123' not found."
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": ["App Environments"],
        "summary": "Create App Environment",
        "description": "Creates a new application environment under the specified Project.",
        "operationId": "createAppEnvironment",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["appEnvironmentName"],
                "properties": {
                  "appEnvironmentName": {
                    "type": "string",
                    "example": "New App Environment",
                    "description": "Name of the new app environment."
                  },
                  "description": {
                    "type": "string",
                    "nullable": true,
                    "example": "Description for the new app environment",
                    "description": "Optional description of the app environment."
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "App Environment successfully created.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "pid": {
                      "type": "integer",
                      "example": 15754
                    },
                    "appEnvironmentName": {
                      "type": "string",
                      "example": "New App Environment"
                    },
                    "description": {
                      "type": "string",
                      "nullable": true,
                      "example": "Description for the new app environment"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad Request Error",
            "content": {
              "application/json": {
                "schema": {},
                "examples": {
                  "invalidName": {
                    "summary": "Name validation error",
                    "value": {
                      "error": "Only alphabet, number, space, period and underscore are allowed in App Environment name."
                    }
                  },
                  "limitReached": {
                    "summary": "Max App Environment limit reached",
                    "value": {
                      "error": "Maximum App Environment limit of 500 reached. Unable to create additional App Environments."
                    }
                  }
                }
              }
            }
          },
          "403": {
            "description": "Forbidden - User does not have permission to create app environment",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string",
                      "example": "User do not have authorization to access this feature."
                    }
                  }
                }
              }
            }
          },
          "422": {
            "description": "Project not found.",
            "content": {
              "application/json": {
                "schema": {},
                "example": {
                  "error": "Project with code 'proj123' not found."
                }
              }
            }
          }
        }
      }
    },
    "/conf/app-environments/{appEnvironmentId}": {
      "put": {
        "tags": ["App Environments"],
        "summary": "Update App Environment",
        "description": "Updates the name or description of an existing app environment.",
        "operationId": "updateAppEnvironment",
        "parameters": [
          {
            "name": "appEnvironmentId",
            "in": "path",
            "required": true,
            "description": "The ID of the App Environment to update.",
            "schema": {
              "type": "integer",
              "example": 15754
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "pid": {
                    "type": "integer",
                    "example": 15754,
                    "description": "The ID of the App Environment to update."
                  },
                  "appEnvironmentName": {
                    "type": "string",
                    "example": "Updated App Environment",
                    "description": "Name of the updated app environment."
                  },
                  "description": {
                    "type": "string",
                    "nullable": true,
                    "example": "Updated description",
                    "description": "Optional updated description of the app environment."
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "App Environment successfully updated.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "pid": {
                      "type": "integer",
                      "example": 15754
                    },
                    "appEnvironmentName": {
                      "type": "string",
                      "example": "Updated App Environment"
                    },
                    "description": {
                      "type": "string",
                      "nullable": true,
                      "example": "Updated description"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad Request. Validation errors occurred.",
            "content": {
              "application/json": {
                "schema": {},
                "example": {
                  "error": "App environment name is required."
                }
              }
            }
          },
          "422": {
            "description": "App Environment or Project not found.",
            "content": {
              "application/json": {
                "schema": {},
                "example": {
                  "error": "App environment with ID '15754' not found."
                }
              }
            }
          }
        }
      },
      "delete": {
        "tags": ["App Environments"],
        "summary": "Delete App Environment",
        "description": "Delete an existing App Environment in the specified Project.",
        "operationId": "deleteAppEnvironment",
        "parameters": [
          {
            "name": "appEnvironmentId",
            "in": "path",
            "required": true,
            "description": "The ID of the App Environment to delete.",
            "schema": {
              "type": "integer",
              "example": 15754
            }
          }
        ],
        "responses": {
          "204": {
            "description": "App Environment successfully deleted."
          },
          "400": {
            "description": "Bad Request. Validation errors occurred.",
            "content": {
              "application/json": {
                "schema": {},
                "example": {
                  "error": "Invalid dataset ID provided."
                }
              }
            }
          },
          "422": {
            "description": "App Environment or Project not found.",
            "content": {
              "application/json": {
                "schema": {},
                "example": {
                  "error": "App environment with ID '15754' not found."
                }
              }
            }
          }
        }
      }
    }
  }
}
