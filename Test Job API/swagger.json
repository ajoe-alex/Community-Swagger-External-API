{
  "openapi": "3.0.0",
  "info": {
    "title": "Job Status Tracking API",
    "version": "1.0.0",
    "description": "API for tracking the status of test jobs. This endpoint allows you to retrieve the execution status and results of a specific test job run."
  },
  "servers": [
    {
      "url": "{accelqLoginUrl}/awb/api/1.0/{tenantCode}",
      "variables": {
        "accelqLoginUrl": {
          "default": "",
          "description": "Base URL for AccelQ login"
        },
        "tenantCode": {
          "default": "your-tenant",
          "description": "Tenant code for identifying the organization"
        }
      }
    }
  ],
  "paths": {
    "/runs/{runPid}": {
      "get": {
        "tags": ["Job Status"],
        "summary": "Get test job run status",
        "description": "Retrieves the current status and results of a test job using its run PID. This includes the overall job status, the total number of test cases, and the counts of passed, failed, and not-run cases.\n\nYou can monitor the status of an ongoing job using the API described below",
        "operationId": "getJobRunStatus",
        "parameters": [
          {
            "name": "runPid",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            },
            "description": "Unique identifier of the test job run",
            "example": 159
          },
          {
            "name": "user_id",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Login username (email)"
          },
          {
            "name": "api_key",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "API key of the user for authentication"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful retrieval of job run status",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "summary": {
                      "type": "object",
                      "description": "Summary information about the test job run"
                    },
                    "parentPid": {
                      "type": "integer",
                      "nullable": true,
                      "description": "Parent job PID if this is a child run"
                    },
                    "childRunSummaryList": {
                      "type": "array",
                      "description": "List of child run summaries",
                      "items": {
                        "type": "object"
                      }
                    },
                    "testRunStoragePurgeInfo": {
                      "type": "object",
                      "nullable": true,
                      "description": "Information about test run storage purge"
                    },
                    "reRunsCount": {
                      "type": "integer",
                      "description": "Number of reruns for this job"
                    }
                  }
                },
                "example": {
                  "summary": {
                    "jobPid": 7092,
                    "status": "completed",
                    "tagList": [],
                    "subStatus": "In progress",
                    "reasons": [],
                    "errors": [],
                    "pass": 1,
                    "fail": 0,
                    "notRun": 0,
